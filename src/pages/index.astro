---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Registro de deberes de saxo</h1>
			<p>
				Sitio estatico para guardar practicas, tareas y notas de estudio con entradas tipo blog y fotos.
			</p>
			<ul>
				<li><a href={`${baseUrl}blog`}>Ver registro</a></li>
				<li><a href={`${baseUrl}buscar`}>Buscar por texto</a></li>
				<li>
					<a href="https://pagescms.org/" target="_blank" rel="noreferrer">Abrir Pages CMS</a>
				</li>
			</ul>
			<h2>Flujo rapido</h2>
			<ol>
				<li>Abre Pages CMS desde el movil e inicia sesion con GitHub.</li>
				<li>Crea una nueva entrada en la coleccion "Entradas de saxo".</li>
				<li>Sube fotos en el campo de imagen y publica.</li>
			</ol>
		</main>
		<Footer />
	</body>
</html>
