---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	objective,
	durationMinutes,
	status,
	attachments,
} =
	Astro.props;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				max-width: 760px;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				font-size: 0.95rem;
				color: rgb(var(--gray));
			}
			.hero-image {
				margin: 1rem 0;
			}
			.hero-image img {
				width: 100%;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				padding: 0;
				list-style: none;
			}
			.tags li {
				font-size: 0.8rem;
				background: rgb(var(--gray-light));
				padding: 0.2rem 0.5rem;
				border-radius: 999px;
			}
			.attachments {
				padding-left: 1.25rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<h1>{title}</h1>
				<p>{description}</p>
				<div class="meta">
					<span><FormattedDate date={pubDate} /></span>
					<span>Estado: {status}</span>
					{durationMinutes && <span>Duracion: {durationMinutes} min</span>}
				</div>
				{updatedDate && <p>Actualizado: <FormattedDate date={updatedDate} /></p>}
				{objective && <p><strong>Objetivo:</strong> {objective}</p>}
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt={`Imagen de la sesion ${title}`} loading="lazy" />
					</div>
				)}
				{tags.length > 0 && (
					<ul class="tags">
						{tags.map((tag) => (
							<li>{tag}</li>
						))}
					</ul>
				)}
				{attachments.length > 0 && (
					<>
						<h2>Adjuntos</h2>
						<ul class="attachments">
							{attachments.map((filePath) => (
								<li>
									<a href={filePath} target="_blank" rel="noreferrer">
										{filePath.split('/').pop()}
									</a>
								</li>
							))}
						</ul>
					</>
				)}
				<hr />
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
