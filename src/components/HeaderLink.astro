---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const rawHref = typeof href === 'string' ? href : '';
const normalizedHref = rawHref.replace(import.meta.env.BASE_URL, '/');
const resolvedHref = rawHref.startsWith('/')
	? `${import.meta.env.BASE_URL}${rawHref.slice(1)}`
	: rawHref;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const isActive =
	normalizedHref === pathname || normalizedHref === '/' + (subpath?.[0] || '');
---

<a href={resolvedHref} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
